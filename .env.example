# ── SQL Server connection ──────────────────────────────────────────────────────
DB_SERVER=HOST\INSTANCE
DB_PORT=1433
DB_NAME=brd_tracker

# SQL Server Authentication
DB_TRUSTED=false
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── Express server port ────────────────────────────────────────────────────────
PORT=3001

# ── Anthropic AI (Knowledge Base Analysis) ────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# AI provider selection: anthropic | openai | gemini | auto
# Falls back automatically through the others on quota/error, then to local rules.
AI_PROVIDER=gemini

# OpenAI (ChatGPT)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Tried in order when the primary model is rate-limited (429) or overloaded (503):
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-flash-latest

# ── Google Docs OAuth2 (for reading private BRD specification documents) ──────
# Create credentials at https://console.cloud.google.com/
#   APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
#   Authorised redirect URI: http://localhost:3001/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Customizer repo (for Affected-Module code scanning) ───────────────────────
CUSTOMIZER_REPO_PATH=C:/path/to/laravel-docker/core/src/customizer-core
